# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# Personal profile data — everything under profiles/ except _example/
profiles/*
!profiles/_example/
!profiles/_example/**

# Shared master pool (candidate-adjacent data)
data/

# Wizard / migration state
.stage*/
**/.stage*/
.gmail-state/
**/.gmail-state/
.gmail-tokens/
**/.gmail-tokens/
.indeed-state/
**/.indeed-state/

# Generated artifacts
*.tsv
!profiles/_example/**/*.tsv
*.pdf
*.docx
!**/node_modules/**/*.pdf
!**/node_modules/**/*.docx

# JD cache
**/jd_cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.cursor/
.claude/

# Obsidian: commit baseline config, ignore volatile per-user state
.obsidian/workspace*.json
.obsidian/graph.json
.obsidian/cache
.obsidian/plugins/*/data.json
**/.obsidian/workspace*.json
**/.obsidian/graph.json
**/.obsidian/cache
**/.obsidian/plugins/*/data.json

# Local one-off / investigation scripts (convention: leading underscore)
scripts/_*.js

# Test / coverage
coverage/
.nyc_output/

# Private notes and docs
CLAUDE.local.md
BACKLOG.md
incidents.md
audit_*.md

# Private maintainer tree (RFC 018) — backlog files, handoffs, pre-anonymization originals
private/

# Build artifacts
dist/
build/
